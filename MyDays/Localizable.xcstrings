      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In the Health app:\n1. Tap your profile (top right)\n2. Privacy → Apps and Services\n3. Select MyDays\n4. Enable the data types"
