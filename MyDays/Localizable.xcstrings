    "onboarding.feature.inbox.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Capture Todos by voice as they come. Sort schedules and categories later."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "할일이 떠오르면 음성으로 빠르게 입력하세요. 일정과 카테고리 분류는 나중에 해도 되요."
